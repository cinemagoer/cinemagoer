# s3-reduce.sh: create smaller versions of .tsv.gz files

set -eu

COUNT="100"
START_DIR="$(pwd)"

if [ "${1:-}" != "" ] ; then
    cd "$1"
fi

mkdir -p partials

for fname in *.tsv.gz
do
    zcat "${fname}" | head -"${COUNT}" | gzip -f - > "partials/${fname}"
done

if [ "${1:-}" != "" ] ; then
    cd "${START_DIR}"
fi
